# ─────────────────────────────────────────────
# Meta Ads API — Credenciais
# Renomeie este arquivo para .env e preencha
# ─────────────────────────────────────────────

# Do painel do seu App em developers.facebook.com
META_APP_ID=SEU_APP_ID_AQUI
META_APP_SECRET=SEU_APP_SECRET_AQUI

# Gerado no Graph API Explorer (token de longa duração)
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI

# Encontrado em business.facebook.com → Contas de anúncios
# Formato obrigatório: act_XXXXXXXXX
META_AD_ACCOUNT_ID=act_XXXXXXXXX

# ─────────────────────────────────────────────
# Google BigQuery (opcional)
# ─────────────────────────────────────────────

# ID do projeto no Google Cloud Console
GCP_PROJECT_ID=SEU_PROJETO_GCP

# Nome do dataset (será criado automaticamente)
BQ_DATASET=meta_ads

# ─────────────────────────────────────────────
# Configuração de extração
# ─────────────────────────────────────────────

# Quantos dias para trás extrair (padrão: 90)
DAYS_LOOKBACK=90
